<!DOCTYPE html>
<html lang="eu">
{% set page_title = tema.meta.number ~ ". Gaia · " ~ tema.meta.title ~ " (" ~ tema.meta.years ~ ") · Historia BTX2" %}
{% set page_description = tema.meta.number ~ ". Gaia: " ~ tema.meta.title ~ " (" ~ tema.meta.years ~ "). " ~ (tema.meta.description or tema.meta.short) %}
{% set page_url = site.base_url ~ "/temas/" ~ (tema.meta.num | format_num) ~ "-" ~ tema.meta.slug ~ ".html" %}
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{{ page_title }}</title>
  <meta name="description" content="{{ page_description }}" />
  <link rel="canonical" href="{{ page_url }}" />
  <meta property="og:locale" content="{{ site.locale }}" />
  <meta property="og:type" content="article" />
  <meta property="og:site_name" content="{{ site.brand.label }}" />
  <meta property="og:title" content="{{ page_title }}" />
  <meta property="og:description" content="{{ page_description }}" />
  <meta property="og:url" content="{{ page_url }}" />
  <meta name="twitter:card" content="summary" />
  <meta name="twitter:title" content="{{ page_title }}" />
  <meta name="twitter:description" content="{{ page_description }}" />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Space+Grotesk:wght@500;600;700&family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="../assets/css/styles.css?v={{ site.cache_version }}" />
  <link rel="icon" href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'%3E%3Crect width='100' height='100' rx='24' fill='%23{{ accent.icon_color }}'/%3E%3Ctext x='50' y='72' font-size='{{ '52' if tema.meta.number == 10 else '58' }}' text-anchor='middle' fill='white' font-family='sans-serif' font-weight='bold'%3E{{ tema.meta.number }}%3C/text%3E%3C/svg%3E" />
  <style>:root { --ca: var(--era-{{ tema.meta.era }}-a); --cb: var(--era-{{ tema.meta.era }}-b); --accent: {{ accent.accent }}; --accent-2: {{ accent.accent2 }}; --accent-ink: {{ accent.ink }}; --accent-tint: {{ accent.tint }}; }</style>
</head>
<body>
  <a class="skip-link" href="#main">Edukira saltatu</a>
  <div class="progress-bar" aria-hidden="true"></div>

  <header class="nav">
    <div class="container">
      <a class="brand" href="../index.html"><span class="logo">H</span><span>{{ site.brand.label }}<small>{{ site.brand.sublabel }}</small></span></a>
      <button class="nav-toggle" aria-label="Menua" aria-expanded="false"><span></span><span></span><span></span></button>
      <nav class="nav-links">
        <a href="../index.html#denbora-lerroa">Denbora-lerroa</a>
        <a href="../index.html#gaiak">Gaiak</a>
        <a href="#glosarioa">Glosarioa</a>
        <a class="cta" href="../index.html">← Hasiera</a>
      </nav>
    </div>
  </header>

  <section class="tema-hero" id="main" tabindex="-1">
    <div class="container">
      <div class="crumbs"><a href="../index.html">Hasiera</a> <span>›</span> <a href="../index.html#gaiak">Gaiak</a> <span>›</span> <span>{{ tema.meta.number }}. Gaia</span></div>
      <div class="gaia-num">{{ tema.meta.number }}. Gaia</div>
      <h1>{{ tema.meta.title }}</h1>
      <div class="hero-meta">
        <span class="years-pill">📅 {{ tema.meta.years }}</span>
        {% if tema.meta.pdf %}<a class="dl-btn" href="../pdf/{{ tema.meta.pdf }}" download>⬇ Deskargatu PDFa</a>{% else %}<a class="dl-btn" href="../pdf/{{ site.apunteak_pdf }}" download>⬇ Apunteak (PDF osoa)</a>{% endif %}
      </div>
    </div>
  </section>

  <div class="container">
    <div class="tema-layout">

      <aside class="tema-side">
        <div class="side-box toc-box">
          <h4>Aurkibidea</h4>
          <nav class="toc">
            {%- for s in tema.sections %}
            <a href="#{{ s.id }}">{{ s.number }} {{ s.toc_label | default(s.title, true) }}</a>
            {%- endfor %}
            <a href="#iturriak">📜 Iturriak</a>
            <a href="#flashcardak">🃏 Flashcardak</a>
            <a href="#glosarioa">📖 Glosarioa</a>
          </nav>
        </div>
        <div class="side-box">
          <h4>Funtsezko datak</h4>
          <ul class="keydates">
            {%- for kd in tema.keydates %}
            <li><span class="kd-year">{{ kd.year }}</span><span class="kd-text">{{ kd.text }}</span></li>
            {%- endfor %}
          </ul>
        </div>
      </aside>

      <article class="tema-content">
        {% if tema.meta.source_note %}
        <div class="callout reveal" style="border-color:#f59e0b;background:#fffbeb">
          <div class="callout-title" style="color:#92400e">ℹ️ Iturri-oharra</div>
          {{ tema.meta.source_note | safe }}
        </div>
        {% endif %}

        <p class="intro-card reveal">{{ tema.intro | safe }}</p>

        {% if tema.timeline %}
        <section class="reveal tema-tl-section">
          <div class="tema-tl-head">📍 Mugarriak · {{ tema.meta.years.replace(' – ', '–') }}</div>
          <div class="timeline" role="list">
            {%- for item in tema.timeline %}
            <a class="tl-item" role="listitem" href="#{{ item.target }}" title="{{ item.desc }}"><span class="tl-dot"></span><span class="tl-year">{{ item.year }}</span><span class="tl-label">{{ item.label }}</span></a>
            {%- endfor %}
          </div>
        </section>
        {% endif %}

        {%- for s in tema.sections %}
        <section id="{{ s.id }}" class="reveal">
          <h2><span class="h-num">{{ s.number }}</span> {{ s.title }}</h2>
          {{ s.body | safe }}
        </section>
        {%- endfor %}

        <section id="iturriak" class="reveal iturri-section">
          <h2><span class="h-num">📜</span> Iturri historikoak</h2>
          {% if tema.meta.iturri_pdf %}
          <p>Azterketako B galderan iruzkintzeko prestatutako iturri historikoak: testuak, irudiak, mapak eta estatistikak, garaiko gertaerak aztertzeko gida-galderekin.</p>
          <div class="iturri-actions">
            <a class="btn btn-soft" href="../pdf/iturri/{{ tema.meta.iturri_pdf }}" target="_blank" rel="noopener">↗ Pantaila osoan ireki</a>
            <a class="btn btn-soft" href="../pdf/iturri/{{ tema.meta.iturri_pdf }}" download>⬇ Deskargatu PDFa</a>
          </div>
          <iframe class="iturri-frame" src="../pdf/iturri/{{ tema.meta.iturri_pdf }}#view=FitH" title="{{ tema.meta.number }}. gaiko iturri historikoak" loading="lazy"></iframe>
          {% else %}
          <div class="iturri-empty">Gai honetarako iturri historikoen bilduma laster gehituko da.</div>
          {% endif %}
        </section>

        <section id="flashcardak" class="reveal flashcards">
          <h2><span class="h-num">🃏</span> Flashcardak: errepasorako</h2>
          <p>Sakatu kartaren gainean iraultzeko. Glosarioko kontzeptuetan eta funtsezko datetan oinarritutako kartak.</p>
          <div class="fc-wrap">
            <div class="fc-card" role="button" tabindex="0" aria-label="Flashcard: sakatu iraultzeko">
              <div class="fc-inner">
                <div class="fc-front">
                  <span class="fc-tag">Kontzeptua</span>
                  <span class="fc-q">…</span>
                  <span class="fc-hint">Sakatu erantzuna ikusteko · Geziak nabigatzeko</span>
                </div>
                <div class="fc-back">
                  <span class="fc-a">…</span>
                  <span class="fc-hint">Sakatu galderara itzultzeko</span>
                </div>
              </div>
            </div>
            <div class="fc-controls">
              <button class="fc-prev" aria-label="Aurreko karta">← Aurrekoa</button>
              <span class="fc-counter">0 / 0</span>
              <button class="fc-next" aria-label="Hurrengo karta">Hurrengoa →</button>
              <button class="fc-shuffle" aria-label="Nahaste kartak">🔀 Nahaste</button>
            </div>
          </div>
        </section>

        <section id="glosarioa" class="reveal">
          <h2><span class="h-num">📖</span> Glosarioa: funtsezko kontzeptuak</h2>
          <p>Gaiko ardatzezko kontzeptuen azalpena. Testuan, lerro etenez azpimarratutako hitzen gainean sakatuz ere ikus ditzakezu definizioak.</p>
          <dl class="glossary-grid">
            {%- for g in tema.glossary %}
            <div class="gloss-item"><dt>{{ g.term }}</dt><dd>{{ g.def | safe }}</dd></div>
            {%- endfor %}
          </dl>
        </section>

        <nav class="tema-pager">
          {%- if pager.prev %}<a href="{{ pager.prev.num | format_num }}-{{ pager.prev.slug }}.html">← {{ pager.prev.num }}. Gaia</a>{% else %}<a href="../index.html">← Hasierara</a>{% endif %}
          {%- if pager.next %}<a href="{{ pager.next.num | format_num }}-{{ pager.next.slug }}.html">{{ pager.next.num }}. Gaia →</a>{% else %}<a href="../index.html">Hasierara →</a>{% endif %}
        </nav>
      </article>

    </div>
  </div>

  <footer class="footer">
    <div class="container">
      <a class="brand" href="../index.html"><span class="logo">H</span><span>{{ site.brand.label }}<small>{{ site.footer_brand_sublabel }}</small></span></a>
      <nav class="foot-links">
        <a href="../index.html#denbora-lerroa">Denbora-lerroa</a>
        <a href="../index.html#gaiak">Gaiak</a>
        <a href="#glosarioa">Glosarioa</a>
      </nav>
      <div class="foot-bottom">
        <span>{{ tema.meta.number }}. Gaia · {{ tema.meta.title }} ({{ tema.meta.years }})</span>
        <span>© <span data-year>{{ current_year }}</span> · {{ site.copyright | safe }}</span>
      </div>
    </div>
  </footer>

  <button class="to-top" aria-label="Gora itzuli">↑</button>
  <script src="../assets/js/app.js?v={{ site.cache_version }}"></script>
</body>
</html>
